# KORA-V5 Environment Configuration
# Copy this file to .env and add your actual credentials

# AWS Credentials (Required for Bedrock Claude + Polly)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-southeast-1

# OpenRouter API (Primary - all agents use OpenRouter + Groq)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API (Legacy - deprecated, use OpenRouter instead)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# NLB Catalogue Integration (Required)
NLB_CATALOGUE_API_TOKEN=your_nlb_api_token_here

# Server Configuration
PORT=4956

# ReadyPlayerMe Avatar
READYPLAYERME_AVATAR_URL=https://models.readyplayer.me/68c431b7c036016545e47f62.glb?morphTargets=ARKit,Oculus+Visemes,mouthOpen,mouthSmile,eyesClosed,eyesLookUp,eyesLookDown&textureSizeLimit=1024&textureFormat=png

# TTS Configuration
POLLY_VOICE_ID=Jasmine

# Optional: Enable debug logging
DEBUG=false
NODE_ENV=production
