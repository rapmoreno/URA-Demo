{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "ura-chatbot",
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(css|js|images|animations)/(.*)", "dest": "/public/$1/$2" },
    { "src": "/", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
